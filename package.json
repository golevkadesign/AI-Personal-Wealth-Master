    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "echarts": "^6.0.0",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "lodash-es": "^4.18.1",
    "longbridge": "^4.0.5",
    "lucide-react": "^0.546.0",
